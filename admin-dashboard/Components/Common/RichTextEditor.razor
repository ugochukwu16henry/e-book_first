@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="rich-editor">
    <div class="rich-editor-toolbar btn-toolbar gap-2 mb-2" role="toolbar" aria-label="Rich text editor toolbar">
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("bold")'><strong>B</strong></button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("italic")'><em>I</em></button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("underline")'><u>U</u></button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("insertUnorderedList")'>• List</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("insertOrderedList")'>1. List</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("formatBlock", "<h2>")'>H2</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("formatBlock", "<blockquote>")'>Quote</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("createLink")'>Link</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => RunCommandAsync("removeFormat")'>Clear</button>
    </div>

    <div id="@_editorId" class="rich-editor-surface form-control" data-placeholder="@Placeholder"
         style="min-height:@Height"></div>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Write your lesson content here...";
    [Parameter] public string Height { get; set; } = "240px";

    private readonly string _editorId = $"rich-editor-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<RichTextEditor>? _selfReference;
    private string _lastValue = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/richTextEditor.js");
            _selfReference = DotNetObjectReference.Create(this);
            _lastValue = Value ?? string.Empty;
            await _module.InvokeVoidAsync("initializeRichTextEditor", _editorId, _selfReference, _lastValue, Placeholder);
            return;
        }

        if (_module is not null && _lastValue != (Value ?? string.Empty))
        {
            _lastValue = Value ?? string.Empty;
            await _module.InvokeVoidAsync("setContent", _editorId, _lastValue);
        }
    }

    [JSInvokable]
    public async Task HandleContentChanged(string html)
    {
        _lastValue = html ?? string.Empty;
        Value = _lastValue;
        await ValueChanged.InvokeAsync(_lastValue);
        StateHasChanged();
    }

    private async Task RunCommandAsync(string command, string? value = null)
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("runCommand", _editorId, command, value);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }

        _selfReference?.Dispose();
    }
}
