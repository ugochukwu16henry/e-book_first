@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center gap-3">
            <div class="fw-semibold text-slate-700">JSON + GitHub eBook CMS</div>
            <AuthorizeView>
                <Authorized Context="authState">
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small">@authState.User.Identity?.Name</span>
                        <a href="http://localhost:3000" target="_blank">Open storefront</a>
                        <form method="post" action="/auth/logout" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
