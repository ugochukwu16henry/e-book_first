@page "/ebooks"
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject JsonEbookRepository Repository
@inject GitHubSyncService GitHubSync
@inject GitAutomationService GitAutomation

<PageTitle>Manage eBooks</PageTitle>

@if (IsLoading)
{
    <div class="py-5 text-center text-muted">Loading your JSON-backed eBook library...</div>
}
else
{
    <div class="d-flex flex-column gap-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <div class="small text-uppercase text-primary fw-semibold mb-1">Role-based editor</div>
                <h1 class="mb-1">Manage eBooks</h1>
                <p class="text-muted mb-0">Edit lessons, topics, chapters, covers, and previews from one dashboard. Active
                    roles: <strong>@CurrentRolesLabel</strong>.</p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-outline-primary" @onclick="AddEbook">New eBook</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveAsync" disabled="@IsSaving">
                        @(IsSaving ? "Saving..." : CanPushChanges ? "Save + Auto Push" : "Save JSON")
                    </button>
                    @if (CanPushChanges)
                    {
                        <button type="button" class="btn btn-dark" @onclick="SyncToGitHubAsync" disabled="@IsSyncing">
                            @(IsSyncing ? "Syncing..." : "Manual GitHub Sync")
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="@StatusCss mb-0">@StatusMessage</div>
            }

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h2 class="h5 mb-0">Library</h2>
                                <span class="badge text-bg-light">@BookItems.Count items</span>
                            </div>

                            <div class="list-group list-group-flush">
                                @foreach (var book in BookItems)
                                {
                                    var isActive = ReferenceEquals(SelectedBook, book);
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(isActive ? "active" : string.Empty)"
                                            @onclick="() => SelectBook(book)">
                                        <div class="fw-semibold">@book.Title</div>
                                        <div class="small @(isActive ? "text-white-50" : "text-muted")">@book.TemplateKey •
                                            @book.Price • PDF: @(book.ShowPdfDownload ? "On" : "Off")</div>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        @if (SelectedBook is null)
                        {
                            <div class="card shadow-sm border-0">
                                <div class="card-body text-muted">Choose or create an eBook to begin editing.</div>
                            </div>
                        }
                        else
                        {
                            <div class="card shadow-sm border-0">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                                        <div>
                                            <h2 class="h4 mb-1">@SelectedBook.Title</h2>
                                            <p class="text-muted mb-0">This editor updates the shared
                                                <code>public/data/ebooks.json</code> content source used by the storefront and PDF
                                                downloads.
                                            </p>
                                        </div>
                                        @if (CanDeleteBooks)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="RemoveSelectedBook">Delete
                                                eBook</button>
                                            }
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Title</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.Title" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Slug</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.Slug" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Badge</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.Badge" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Price</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.Price" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">PDF template</label>
                                                <InputSelect class="form-select" @bind-Value="SelectedBook.TemplateKey">
                                                    @foreach (var template in Templates)
                                                    {
                                                        <option value="@template.Key">@template.Name</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-12">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <label class="form-label mb-0">Template preview</label>
                                                    <span class="small text-muted">Selected: @GetSelectedTemplateName()</span>
                                                </div>
                                                <div class="template-preview-grid">
                                                    @foreach (var template in Templates)
                                                    {
                                                        var isSelectedTemplate = string.Equals(SelectedBook.TemplateKey, template.Key,
                            StringComparison.OrdinalIgnoreCase);
                                                        <button type="button"
                                                                class="template-preview-card @(isSelectedTemplate ? "selected" : string.Empty)"
                                                                @onclick="() => SelectTemplate(template.Key)">
                                                            <div class="template-preview-art @GetTemplatePreviewClass(template.Key)">
                                                                <span class="template-preview-chip">@template.Key</span>
                                                                <span class="template-preview-line long"></span>
                                                                <span class="template-preview-line"></span>
                                                                <span class="template-preview-line short"></span>
                                                            </div>
                                                            <div class="template-preview-body">
                                                                <div class="fw-semibold">@template.Name</div>
                                                                <div class="small text-muted">@template.Description</div>
                                                            </div>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Cover image path</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.CoverImagePath" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Upload cover image</label>
                                                <InputFile class="form-control" OnChange="UploadCoverAsync" accept="image/*" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">PDF filename</label>
                                                <InputText class="form-control" @bind-Value="SelectedBook.PdfFileName" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label d-block">Public PDF button visibility</label>
                                                <div class="form-check mt-2">
                                                    <InputCheckbox class="form-check-input" @bind-Value="SelectedBook.ShowPdfDownload" />
                                                    <label class="form-check-label">Show “Download PDF” on the homepage storefront and the
                                                        public eBook page</label>
                                                    </div>
                                                    <div class="form-text">If you turn this off, the public Download PDF button is hidden on
                                                        both the storefront card and the eBook page. Admin download access stays available
                                                        below.</div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Selar URL</label>
                                                        <InputText class="form-control" @bind-Value="SelectedBook.SelarUrl" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Format label</label>
                                                        <InputText class="form-control" @bind-Value="SelectedBook.Format" />
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(SelectedBook.CoverImagePath))
                                                    {
                                                        <div class="col-md-6">
                                                            <label class="form-label d-block">Cover preview</label>
                                                            <img src="@SelectedBook.CoverImagePath" alt="@SelectedBook.Title"
                                                                 class="img-fluid rounded-3 border" style="max-height: 200px;" />
                                                        </div>
                                                    }

                                                    <div class="col-12">
                                                        <label class="form-label d-block">Admin PDF access</label>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            <a class="btn btn-outline-secondary btn-sm" href="@GetStorefrontBookUrl()"
                                                               target="_blank" rel="noreferrer">Open eBook page</a>
                                                            <a class="btn btn-outline-primary btn-sm" href="@GetAdminDownloadUrl()" target="_blank"
                                                               rel="noreferrer">Open / Download PDF</a>
                                                        </div>
                                                        <div class="form-text">Use this when you want to download the PDF yourself and upload it to
                                                            Selar.</div>
                                                        </div>
                                                        <div class="col-12">
                                                            <label class="form-label">Description</label>
                                                            <InputTextArea class="form-control" rows="3" @bind-Value="SelectedBook.Description" />
                                                        </div>
                                                        <div class="col-12">
                                                            <label class="form-label">Intro</label>
                                                            <RichTextEditor @bind-Value="SelectedBook.Intro" Height="180px"
                                                                            Placeholder="Write the eBook introduction..." />
                                                        </div>
                                                        <div class="col-12">
                                                            <label class="form-label">Closing note</label>
                                                            <RichTextEditor @bind-Value="SelectedBook.ClosingNote" Height="160px"
                                                                            Placeholder="Write the closing note for readers..." />
                                                        </div>
                                                    </div>

                                                    <hr class="my-4" />

                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <div>
                                                            <h3 class="h5 mb-1">Chapters & lesson content</h3>
                                                            <p class="text-muted mb-0">Add new chapters, delete old ones, and use the rich text editor
                                                                for lesson writing.</p>
                                                            </div>
                                                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddChapter">Add
                                                                chapter</button>
                                                            </div>

                                                            <div class="d-flex flex-column gap-3">
                                                                @for (var index = 0; index < SelectedBook.Chapters.Count; index++)
                                                                {
                                                                    var chapter = SelectedBook.Chapters[index];
                                                                    <div class="border rounded-3 p-3 bg-light-subtle">
                                                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                                                            <strong>Chapter @(@index + 1)</strong>
                                                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                                                    @onclick="() => RemoveChapter(chapter)">Remove</button>
                                                                        </div>

                                                                        <div class="row g-3">
                                                                            <div class="col-12">
                                                                                <label class="form-label">Chapter title</label>
                                                                                <InputText class="form-control" @bind-Value="chapter.Title" />
                                                                            </div>
                                                                            <div class="col-12">
                                                                                <label class="form-label">Summary / topic</label>
                                                                                <InputTextArea class="form-control" rows="2" @bind-Value="chapter.Summary" />
                                                                            </div>
                                                                            <div class="col-12">
                                                                                <label class="form-label">Lesson content</label>
                                                                                <RichTextEditor @bind-Value="chapter.Content" Height="260px"
                                                                                                Placeholder="Write the full lesson content here using short paragraphs, headings, and polished spacing..." />
                                                                                <div class="form-text">Use paragraphs, short sections, and an optional illustration
                                                                                    to make the chapter read like a professional eBook.</div>
                                                                                </div>
                                                                                <div class="col-12">
                                                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                        <label class="form-label mb-0">Illustration gallery blocks</label>
                                                                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                                                @onclick="() => AddIllustration(chapter)">Add image block</button>
                                                                                    </div>
                                                                                    <div class="form-text mb-3">Add one or more professional illustrations for this
                                                                                        chapter. Each image can have its own caption and will appear in the PDF.</div>

                                                                                        @if (chapter.Illustrations.Count == 0)
                                                                                        {
                                                                                            <div class="small text-muted">No chapter illustrations yet. Add an image block to
                                                                                                create a professional visual section.</div>
                                                                                            }
                                                                                    else
                                                                                            {
                                                                                                <div class="d-flex flex-column gap-3">
                                                                                                    @foreach (var illustration in chapter.Illustrations)
                                                                                                    {
                                                                                                        <div class="border rounded-3 p-3 bg-white">
                                                                                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                                                                                <strong>Illustration block</strong>
                                                                                                                <div class="d-flex gap-2">
                                                                                                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                                                                            @onclick="() => MoveIllustrationUp(chapter, illustration)">↑</button>
                                                                                                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                                                                            @onclick="() => MoveIllustrationDown(chapter, illustration)">↓</button>
                                                                                                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                                                                                                            @onclick="() => RemoveIllustration(chapter, illustration)">Remove</button>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <div class="row g-3">
                                                                                                                <div class="col-md-6">
                                                                                                                    <label class="form-label">Image path</label>
                                                                                                                    <InputText class="form-control"
                                                                                                                               @bind-Value="illustration.ImagePath" />
                                                                                                                </div>
                                                                                                                <div class="col-md-6">
                                                                                                                    <label class="form-label">Upload image</label>
                                                                                                                    <InputFile class="form-control"
                                                                                                                               OnChange="args => UploadChapterIllustrationAsync(chapter, illustration, args)"
                                                                                                                               accept="image/*" />
                                                                                                                </div>
                                                                                                                <div class="col-md-8">
                                                                                                                    <label class="form-label">Caption</label>
                                                                                                                    <InputText class="form-control"
                                                                                                                               @bind-Value="illustration.Caption" />
                                                                                                                </div>
                                                                                                                <div class="col-md-4">
                                                                                                                    <label class="form-label">Place after text block #</label>
                                                                                                                    <InputNumber class="form-control"
                                                                                                                                 @bind-Value="illustration.PlacementAfterParagraph" />
                                                                                                                    <div class="form-text">0 = before the first paragraph, 1 = after the
                                                                                                                        first paragraph or subtopic.</div>
                                                                                                                    </div>
                                                                                                                    @if (!string.IsNullOrWhiteSpace(illustration.ImagePath))
                                                                                                                    {
                                                                                                                        <div class="col-12">
                                                                                                                            <img src="@illustration.ImagePath" alt="@chapter.Title"
                                                                                                                                 class="img-fluid rounded-3 border"
                                                                                                                                 style="max-height: 240px; object-fit: cover;" />
                                                                                                                            <div class="small text-muted mt-2">Placed after text block
                                                                                                                                @illustration.PlacementAfterParagraph</div>
                                                                                                                                @if (!string.IsNullOrWhiteSpace(illustration.Caption))
                                                                                                                                {
                                                                                                                                    <div class="small text-muted mt-1">@illustration.Caption</div>
                                                                                                                                }
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }
                                                                                                        </div>
                                                                                                    }
                                                                                                </div>
                                                                                                <div class="col-md-6">
                                                                                                    <label class="form-label">Reflection prompts (one per line)</label>
                                                                                                    <InputTextArea class="form-control" rows="5" @bind-Value="chapter.PromptsText" />
                                                                                                </div>
                                                                                                <div class="col-md-6">
                                                                                                    <label class="form-label">Key takeaway</label>
                                                                                                    <InputTextArea class="form-control" rows="5" @bind-Value="chapter.Takeaway" />
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    }
                                                                                </div>

                                                                                <div class="card border-0 bg-body-tertiary mt-4">
                                                                                    <div class="card-body">
                                                                                        <h3 class="h5 mb-2">Preview this eBook</h3>
                                                                                        <p class="text-muted">Review the content exactly as it will flow into your storefront and
                                                                                            PDF generator.</p>

                                                                                            <h4 class="h6 mb-1">@SelectedBook.Title</h4>
                                                                                            <p class="text-muted">@SelectedBook.Description</p>
                                                                                            <div class="mb-3">@((MarkupString)(SelectedBook.Intro ?? string.Empty))</div>

                                                                                            <div class="d-flex flex-column gap-3">
                                                                                                @foreach (var chapter in SelectedBook.Chapters)
                                                                                                {
                                                                                                    <div class="border rounded-3 p-3 bg-white">
                                                                                                        <div class="fw-semibold">@chapter.Title</div>
                                                                                                        <div class="text-muted small mb-2">@chapter.Summary</div>
                                                                                                        @if (chapter.Illustrations.Count > 0)
                                                                                                        {
                                                                                                            <div class="row g-3 mb-3">
                                                                                                                @foreach (var illustration in chapter.Illustrations.Where(item =>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        !string.IsNullOrWhiteSpace(item.ImagePath)))
                                                                                                                {
                                                                                                                    <div class="col-md-6">
                                                                                                                        <div class="border rounded-3 overflow-hidden bg-light">
                                                                                                                            <img src="@illustration.ImagePath" alt="@chapter.Title"
                                                                                                                                 class="img-fluid w-100"
                                                                                                                                 style="max-height: 220px; object-fit: cover;" />
                                                                                                                            <div class="small text-muted p-2">
                                                                                                                                @if (!string.IsNullOrWhiteSpace(illustration.Caption))
                                                                                                                                {
                                                                                                                                    <span>@illustration.Caption</span>
                                                                                                                                }
                                                                                                                                <span class="ms-2">• After text block
                                                                                                                                    @illustration.PlacementAfterParagraph</span>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    }
                                                                                                                </div>
                                                                                                            }
                                                                                                            <div>@((MarkupString)(chapter.Content ?? string.Empty))</div>
                                                                                                            @if (chapter.Prompts.Count > 0)
                                                                                                            {
                                                                                                                <ul class="mt-2 mb-2">
                                                                                                                    @foreach (var prompt in chapter.Prompts)
                                                                                                                    {
                                                                                                                        <li>@prompt</li>
                                                                                                                    }
                                                                                                                </ul>
                                                                                                            }
                                                                                                            @if (!string.IsNullOrWhiteSpace(chapter.Takeaway))
                                                                                                            {
                                                                                                                <div class="small text-primary fw-semibold">Takeaway: @chapter.Takeaway</div>
                                                                                                            }
                                                                                                        </div>
                                                                                                    }
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }

@code {
    private List<EbookRecord> BookItems { get; set; } = [];
    private List<PdfTemplateOption> Templates { get; set; } = [];
    private EbookRecord? SelectedBook { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsSyncing { get; set; }
    private bool CanDeleteBooks { get; set; }
    private bool CanPushChanges { get; set; }
    private string CurrentRolesLabel { get; set; } = "Admin";
    private string? StatusMessage { get; set; }
    private string StatusCss { get; set; } = "alert alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadPermissionsAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        BookItems = await Repository.GetAllAsync();
        Templates = await Repository.GetTemplatesAsync();
        NormalizeChapterIllustrations();
        SelectedBook = BookItems.FirstOrDefault();
        IsLoading = false;
    }

    private async Task LoadPermissionsAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        CanDeleteBooks = user.IsInRole("SuperAdmin");
        CanPushChanges = user.IsInRole("SuperAdmin");

        var roles = new[] { "SuperAdmin", "Editor", "Admin" }
            .Where(user.IsInRole)
            .Distinct()
            .ToArray();

        CurrentRolesLabel = roles.Length > 0 ? string.Join(", ", roles) : "Admin";
    }

    private void SelectBook(EbookRecord book) => SelectedBook = book;

    private string GetStorefrontBookUrl()
    {
        if (SelectedBook is null || string.IsNullOrWhiteSpace(SelectedBook.Slug))
        {
            return "http://localhost:3000/";
        }

        return $"http://localhost:3000/books/{Uri.EscapeDataString(SelectedBook.Slug)}";
    }

    private string GetAdminDownloadUrl()
    {
        if (SelectedBook is null || string.IsNullOrWhiteSpace(SelectedBook.Slug))
        {
            return "http://localhost:3000/";
        }

        return $"http://localhost:3000/books/{Uri.EscapeDataString(SelectedBook.Slug)}?adminDownload=1";
    }

    private void SelectTemplate(string key)
    {
        if (SelectedBook is not null && !string.IsNullOrWhiteSpace(key))
        {
            SelectedBook.TemplateKey = key;
        }
    }

    private string GetSelectedTemplateName()
    {
        var selectedKey = SelectedBook?.TemplateKey;
        return Templates.FirstOrDefault(template => string.Equals(template.Key, selectedKey,
StringComparison.OrdinalIgnoreCase))?.Name
            ?? "Custom template";
    }

    private static string GetTemplatePreviewClass(string? key) => key?.ToLowerInvariant() switch
    {
        "premium" => "template-premium",
        "classic" => "template-classic",
        "minimal" => "template-minimal",
        "relaxed" => "template-relaxed",
        "relaxed-book" => "template-relaxed-book",
        "relaxed-report" => "template-relaxed-report",
        "relaxed-paper" => "template-relaxed-paper",
        "relaxed-letter" => "template-relaxed-letter",
        _ => "template-premium"
    };

    private void AddEbook()
    {
        var uniqueId = Guid.NewGuid().ToString("N")[..6];
        var book = new EbookRecord
        {
            Title = "New eBook Title",
            Slug = $"new-ebook-{uniqueId}",
            Badge = "Draft",
            Price = "$0",
            Format = "Instant PDF download",
            CoverImagePath = "/images/e-book-cover.svg",
            PdfFileName = $"new-ebook-{uniqueId}.pdf",
            ShowPdfDownload = true,
            SelarUrl = "https://selar.co/your-product-link",
            TemplateKey = Templates.FirstOrDefault()?.Key ?? "premium",
            Description = "Add a short sales description for this eBook.",
            Intro = "<p>Add the intro content that should appear on the product page and in the PDF.</p>",
            ClosingNote = "<p>Add a strong closing note for readers.</p>",
            Chapters =
            [
                new ChapterRecord
                {
                    Title = "Chapter 1: New Lesson",
                    Summary = "Introduce the first lesson here.",
                    Content = "<p>Write the lesson content here.</p>",
                    IllustrationImagePath = string.Empty,
                    IllustrationCaption = string.Empty,
                    Illustrations = [],
                    Prompts = ["Add a reflection prompt"],
                    Takeaway = "Summarize the key lesson."
                }
            ]
        };

        BookItems.Insert(0, book);
        SelectedBook = book;
        SetStatus("New eBook draft created. Update the fields and save when ready.", "alert alert-info");
    }

    private void RemoveSelectedBook()
    {
        if (SelectedBook is null)
        {
            return;
        }

        BookItems.Remove(SelectedBook);
        SelectedBook = BookItems.FirstOrDefault();
        SetStatus("The selected eBook was removed from the local JSON list. Save to persist the change.", "alert alert-warning");
    }

    private void AddChapter()
    {
        SelectedBook?.Chapters.Add(new ChapterRecord
        {
            Title = $"Chapter {(SelectedBook?.Chapters.Count ?? 0) + 1}: New Lesson",
            Summary = "Add a short summary.",
            Content = "<p>Write the full lesson content here.</p>",
            IllustrationImagePath = string.Empty,
            IllustrationCaption = string.Empty,
            Illustrations = [],
            Prompts = ["Add a reflection prompt"],
            Takeaway = "Add a takeaway."
        });
    }

    private void RemoveChapter(ChapterRecord chapter)
    {
        SelectedBook?.Chapters.Remove(chapter);
    }

    private async Task UploadCoverAsync(InputFileChangeEventArgs eventArgs)
    {
        if (SelectedBook is null || eventArgs.FileCount == 0)
        {
            return;
        }

        var file = eventArgs.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        SelectedBook.CoverImagePath = await Repository.SaveCoverImageAsync(file.Name, stream);
        SetStatus("Cover image uploaded. Save to update the shared JSON and push the change.", "alert alert-success");
    }

    private void NormalizeChapterIllustrations()
    {
        foreach (var book in BookItems)
        {
            foreach (var chapter in book.Chapters)
            {
                chapter.Illustrations ??= [];

                if (chapter.Illustrations.Count == 0 && !string.IsNullOrWhiteSpace(chapter.IllustrationImagePath))
                {
                    chapter.Illustrations.Add(new ChapterIllustrationRecord
                    {
                        ImagePath = chapter.IllustrationImagePath,
                        Caption = chapter.IllustrationCaption,
                        PlacementAfterParagraph = 1
                    });
                }

                foreach (var illustration in chapter.Illustrations)
                {
                    illustration.PlacementAfterParagraph = Math.Max(0, illustration.PlacementAfterParagraph);
                }

                SyncLegacyIllustrationFields(chapter);
            }
        }
    }

    private static void SyncLegacyIllustrationFields(ChapterRecord chapter)
    {
        chapter.Illustrations ??= [];
        var firstIllustration = chapter.Illustrations.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ImagePath));
        chapter.IllustrationImagePath = firstIllustration?.ImagePath ?? string.Empty;
        chapter.IllustrationCaption = firstIllustration?.Caption ?? string.Empty;
    }

    private void AddIllustration(ChapterRecord chapter)
    {
        chapter.Illustrations ??= [];
        chapter.Illustrations.Add(new ChapterIllustrationRecord
        {
            PlacementAfterParagraph = Math.Max(1, chapter.Illustrations.Count + 1)
        });
    }

    private void MoveIllustrationUp(ChapterRecord chapter, ChapterIllustrationRecord illustration)
    {
        MoveIllustration(chapter, illustration, -1);
    }

    private void MoveIllustrationDown(ChapterRecord chapter, ChapterIllustrationRecord illustration)
    {
        MoveIllustration(chapter, illustration, 1);
    }

    private void MoveIllustration(ChapterRecord chapter, ChapterIllustrationRecord illustration, int direction)
    {
        chapter.Illustrations ??= [];
        var currentIndex = chapter.Illustrations.IndexOf(illustration);
        if (currentIndex < 0)
        {
            return;
        }

        var targetIndex = currentIndex + direction;
        if (targetIndex < 0 || targetIndex >= chapter.Illustrations.Count)
        {
            return;
        }

        (chapter.Illustrations[currentIndex], chapter.Illustrations[targetIndex]) =
            (chapter.Illustrations[targetIndex], chapter.Illustrations[currentIndex]);

        for (var index = 0; index < chapter.Illustrations.Count; index++)
        {
            chapter.Illustrations[index].PlacementAfterParagraph = index + 1;
        }

        SyncLegacyIllustrationFields(chapter);
    }

    private void RemoveIllustration(ChapterRecord chapter, ChapterIllustrationRecord illustration)
    {
        chapter.Illustrations?.Remove(illustration);

        if (chapter.Illustrations is not null)
        {
            for (var index = 0; index < chapter.Illustrations.Count; index++)
            {
                chapter.Illustrations[index].PlacementAfterParagraph = index + 1;
            }
        }

        SyncLegacyIllustrationFields(chapter);
    }

    private async Task UploadChapterIllustrationAsync(ChapterRecord chapter, ChapterIllustrationRecord illustration,
InputFileChangeEventArgs eventArgs)
    {
        if (SelectedBook is null || eventArgs.FileCount == 0)
        {
            return;
        }

        var file = eventArgs.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        illustration.ImagePath = await Repository.SaveCoverImageAsync(file.Name, stream);

        if (string.IsNullOrWhiteSpace(illustration.Caption))
        {
            illustration.Caption = $"{chapter.Title} illustration";
        }

        SyncLegacyIllustrationFields(chapter);
        SetStatus("Chapter illustration uploaded. Save to include it in the public preview and downloaded PDF.", "alert alert-success");
    }

    private async Task SaveAsync()
    {
        IsSaving = true;
        NormalizeChapterIllustrations();
        await Repository.SaveAllAsync(BookItems);

        if (CanPushChanges)
        {
            var gitResult = await GitAutomation.CommitAndPushAsync();
            SetStatus(gitResult.Message, gitResult.Success ? "alert alert-success" : "alert alert-warning");
        }
        else
        {
            SetStatus("Saved locally to public/data/ebooks.json. A SuperAdmin can now push the changes to GitHub.", "alert alert-success");
        }

        IsSaving = false;
    }

    private async Task SyncToGitHubAsync()
    {
        if (!CanPushChanges)
        {
            SetStatus("Only SuperAdmin users can push content changes to GitHub.", "alert alert-warning");
            return;
        }

        IsSyncing = true;
        await Repository.SaveAllAsync(BookItems);
        var result = await GitHubSync.SyncEbooksAsync();
        IsSyncing = false;
        SetStatus(result.Message, result.Success ? "alert alert-success" : "alert alert-warning");
    }

    private void SetStatus(string message, string cssClass)
    {
        StatusMessage = message;
        StatusCss = cssClass;
    }
}
