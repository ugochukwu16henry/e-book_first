@page "/login"
@attribute [AllowAnonymous]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Admin Login</PageTitle>

<div class="d-flex min-vh-100 align-items-center justify-content-center bg-body-tertiary px-3">
    <div class="card border-0 shadow-sm" style="max-width: 460px; width: 100%;">
        <div class="card-body p-4 p-md-5">
            <div class="mb-4 text-center">
                <div class="small text-uppercase text-primary fw-semibold mb-2">Admin Access</div>
                <h1 class="h3 mb-2">Sign in to manage your eBooks</h1>
                <p class="text-muted mb-0">Sign in with your admin account to manage books, lessons, and PDF templates.
                    Sessions expire automatically after inactivity based on the configured timeout.</p>
                </div>

                @if (_showError)
                {
                    <div class="alert alert-danger">Sign-in failed. Check your email or password and try again.</div>
                }

                @if (_showSignedOut)
                {
                    <div class="alert alert-success">You have been signed out.</div>
                }

                <form method="post" action="/auth/login">
                    <input type="hidden" name="returnUrl" value="@_returnUrl" />

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" name="email" autocomplete="username" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input class="form-control" type="password" name="password" autocomplete="current-password"
                               required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Sign in</button>
                </form>
            </div>
        </div>
    </div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? SignedOut { get; set; }

    private string _returnUrl = "/";
    private bool _showError;
    private bool _showSignedOut;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        _returnUrl = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl!;
        _showError = string.Equals(Error, "1", StringComparison.OrdinalIgnoreCase);
        _showSignedOut = string.Equals(SignedOut, "1", StringComparison.OrdinalIgnoreCase);
    }
}
